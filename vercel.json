{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "taxisprovencaleaix.fr" }],
      "destination": "https://www.taxisprovencaleaix.fr/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/services", "destination": "/services/index.html" },
    { "source": "/flotte", "destination": "/flotte/index.html" },
    { "source": "/a-propos", "destination": "/a-propos/index.html" },
    { "source": "/contact", "destination": "/contact/index.html" },
    { "source": "/mentions-legales", "destination": "/mentions-legales/index.html" },
    { "source": "/taxi-aeroport-marseille-aix-en-provence", "destination": "/taxi-aeroport-marseille-aix-en-provence/index.html" },
    { "source": "/taxi-gare-tgv-aix-en-provence", "destination": "/taxi-gare-tgv-aix-en-provence/index.html" },
    { "source": "/vtc-luberon-gordes-cassis", "destination": "/vtc-luberon-gordes-cassis/index.html" },
    { "source": "/chauffeur-prive-mariage-aix", "destination": "/chauffeur-prive-mariage-aix/index.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Permissions-Policy", "value": "geolocation=(), microphone=(), camera=()" }
      ]
    }
  ]
}
