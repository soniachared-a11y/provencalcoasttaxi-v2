{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/services", "destination": "/services/index.html" },
    { "source": "/flotte", "destination": "/flotte/index.html" },
    { "source": "/a-propos", "destination": "/a-propos/index.html" },
    { "source": "/contact", "destination": "/contact/index.html" },
    { "source": "/mentions-legales", "destination": "/mentions-legales/index.html" },
    { "source": "/taxi-aeroport-marseille-aix-en-provence", "destination": "/taxi-aeroport-marseille-aix-en-provence/index.html" },
    { "source": "/taxi-gare-tgv-aix-en-provence", "destination": "/taxi-gare-tgv-aix-en-provence/index.html" },
    { "source": "/vtc-luberon-gordes-cassis", "destination": "/vtc-luberon-gordes-cassis/index.html" },
    { "source": "/chauffeur-prive-mariage-aix", "destination": "/chauffeur-prive-mariage-aix/index.html" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
